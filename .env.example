# ============================================================
# Variables para desarrollo local (no se usan en Vercel)
# Vercel inyecta automáticamente POSTGRES_PRISMA_URL al conectar Neon.
# ============================================================

# Base de datos PostgreSQL local
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/crm_hvac?schema=public"

# JWT — genera uno con: openssl rand -base64 32
JWT_SECRET="reemplazar-por-secret-aleatorio-de-al-menos-32-caracteres"

# App
NEXT_PUBLIC_APP_NAME="Ductos & Climatización CRM"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
